PORT=3000
UPLOAD_WEBHOOK_PATH=/webhook/upload-voice-memo
# Optional: require this header on upload requests: x-upload-token
# UPLOAD_AUTH_TOKEN=replace-with-long-random-token

# Local STT via faster-whisper
STT_COMMAND_TEMPLATE=.venv/bin/python scripts/transcribe_faster_whisper.py {input}
WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
STT_TIMEOUT_MS=240000
